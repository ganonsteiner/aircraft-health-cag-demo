# Copy to .env and configure at least one LLM (see README.md → "Run the AI Assistant with a local model").

# ── Option A: Anthropic (recommended — higher performance) ───────────────────
# If you set a valid key here, the app uses Anthropic and ignores LOCAL_LLM_* below.
# Get a key: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── Option B: Local LLM via Ollama (lower performance) ─────────────────────────
# Use only when ANTHROPIC_API_KEY is empty. Full steps are in README.md; summary:
#
#   1. Install and start Ollama: https://ollama.com/download
#   2. Verify: curl -s http://localhost:11434/api/tags
#   3. Pull the best default model: ollama pull qwen2.5:14b   (~9 GB)
#      Backup if too heavy:      ollama pull qwen2.5:7b     (~5 GB) + set LOCAL_LLM_MODEL below
#   4. Uncomment BOTH lines below (URL must include /v1)
#   5. From aircraft-health-cag-demo/: npm run dev
#
# Performance is much worse than Anthropic on complex graph + tool queries.
#
# LOCAL_LLM_URL=http://localhost:11434/v1
# LOCAL_LLM_MODEL=qwen2.5:14b

# ── Mock CDF (defaults are fine for local dev; uncomment to override) ──────────
# CDF_BASE_URL=http://localhost:4001
# CDF_TOKEN=mock-token
# CDF_PROJECT=desert_sky

# ── Optional: reproducible dataset dates (YYYY-MM-DD)
# DESERT_SKY_DEMO_DATE=YYYY-MM-DD
